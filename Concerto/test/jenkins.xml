<?xml version="1.0" encoding="UTF-8" ?>
<phpunit
	bootstrap='.\bootstrap.php'
>
	<php>
		<var name="DB_DSN" value="pgsql:host=localhost port=5430" />
		<var name="DB_USER" value="postgres" />
		<var name="DB_PASSWD" value="manager" />
		<var name="DB_DBNAME" value="itc_work1" />
		
		<!-- E_ALL & !E_DEPRECATED & ! E_STRICT & !E_STRICT -->
		<ini name="error_reporting" value="6143"/>
		
		<!-- desable xdebug var_dump -->
		<ini name="xdebug.var_display_max_children" value="-1" />
		<ini name="xdebug.var_display_max_data" value="-1" />
		<ini name="xdebug.var_display_max_depth" value="-1" />
		
	</php>
	
	<testsuites>
		<testsuite name="main">
			<directory>.\</directory>
		</testsuite>
	</testsuites>
	
  <filter>
    <whitelist processUncoveredFilesFromWhitelist="true" addUncoveredFilesFromWhitelist="true">
      <directory suffix=".php">d:\Public\www\itc_develop\itc_main.files\_mvc\Concerto\</directory>
      <exclude>
        <directory>d:\Public\www\itc_develop\itc_main.files\_mvc\Concerto\@\</directory>
        <directory>d:\Public\www\itc_develop\itc_main.files\_mvc\Concerto\test\</directory>
      </exclude>
    </whitelist>
  </filter>

  <logging>
	<log type="coverage-html" target=".\_log\coverage" />
	<log type="coverage-clover" target=".\_log\clover.xml" />
	<log type="coverage-crap4j" target=".\_log\crap4j.xml" />
	<log type="junit" target=".\_log\phpunit.xml" />
  </logging>
  
</phpunit>
